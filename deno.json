{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "@kotsumo/sawcase": "../sawcase/mod.ts",
    "@kotsumo/sawcase/components": "../sawcase/src/components/mod.ts",
    "@kotsumo/sawcase/components/": "../sawcase/src/components/",
    "@kotsumo/sawcase/styles": "../sawcase/styles.ts",
    "@deno/gfm": "jsr:@deno/gfm@^0.12.0",
    "@zag-js/clipboard": "npm:@zag-js/clipboard@^1.42.0",
    "@zag-js/preact": "npm:@zag-js/preact@^1.42.0",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "lucide-preact": "npm:lucide-preact@^1.23.0",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
